{
  "manifest_version": 3,
  "name": "Myntra Wishlist Price Tracker",
  "version": "1.0.0",
  "description": "Tracks Myntra wishlist prices and sends alerts.",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.myntra.com/*",
    "https://api.emailjs.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icons/icon.png"
  }
}